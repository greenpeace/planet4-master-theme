{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "planet4-blocks/happypoint",
  "category": "planet4-blocks",
  "description": "The Happy Point block embeds (via iFrame) a \"Subscribe\" or engagement form on top of a full-width background image.",
  "title": "Happy Point",
  "icon": "format-image",
  "attributes": {
    "focus_image": {
      "type": "string"
    },
    "opacity": {
      "type": "number",
      "default": 30
    },
    "mailing_list_iframe": {
      "type": "boolean"
    },
    "iframe_url": {
      "type": "string"
    },
    "id": {
      "type": "number"
    },
    "use_embed_code": {
      "type": "boolean"
    },
    "embed_code": {
      "type": "string"
    },
    "override_default_content": {
      "type": "boolean",
      "default": false
    },
    "local_content_provider": {
      "type": "string",
      "default": "none"
    }
  },
  "supports": {
    "multiple": false,
    "html": false
  },
  "editorScript": "file:index.js"
}
