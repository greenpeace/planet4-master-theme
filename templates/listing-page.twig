<main class="page-content container" id="content">
    {% if not post.password_required %}
        {% include 'blocks/header.twig' %}
    {% endif %}

    {% if featured_posts_content is defined %}
        {{ featured_posts_content|raw }}
    {% endif %}
    <div class="wp-block-separator is-style-wide listing-page-separator"></div>
    <div class="d-flex align-items-center justify-content-between listing-page-title">
        {% if fn('is_home') %}
            <h2 tabindex="0" class="visually-hidden">{{__( 'Filter posts', 'planet4-master-theme' ) }}</h2>
            <div id="listing-page-filters"></div>
        {% else %}
            <h2>{{ listing_page_title ?? __( 'All articles', 'planet4-master-theme' ) }}</h2>
        {% endif %}
        <div id="listing-page-layout-toggle" class="layout-button-ctn">
        </div>
    </div>
    <div>
        {% if fn('is_home') %}
            <h2 tabindex="0" class="visually-hidden">{{__( 'Filtered results', 'planet4-master-theme' ) }}</h2>
        {% endif %}
        <div id="listing-page-content"></div>
    </div>
</main>
